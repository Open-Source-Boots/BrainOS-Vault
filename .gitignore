# ============================================================
# BRAINOS VAULT — .gitignore
# Device-aware: Desktop/PC, Laptop, iPhone, iPad
# Last updated: 2026-04-27
# ============================================================

# ------------------------------------------------------------
# SYNCTHING ARTIFACTS (all devices)
# ------------------------------------------------------------
.stfolder
.stfolder/
.stfolder.removed-*/
.stignore
~syncthing~*
*.sync-conflict-*

# ------------------------------------------------------------
# OBSIDIAN SYNC CONFLICTS (all devices)
# Obsidian Sync and third-party sync tools both produce these
# ------------------------------------------------------------
.obsidian/*.sync-conflict-*.json

# ------------------------------------------------------------
# OBSIDIAN WORKSPACE STATE
# workspace.json and workspace-mobile.json are per-device UI
# state — committing them causes constant noise and conflicts
# between Desktop, Laptop, iPhone, and iPad views
# ------------------------------------------------------------
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ------------------------------------------------------------
# OBSIDIAN PLUGIN DATA (selective)
# Plugin config that is machine-specific or contains tokens
# ------------------------------------------------------------
.obsidian/plugins/google-drive-sync/
.obsidian/plugins/smart-connections/

# ------------------------------------------------------------
# SMART CONNECTIONS CACHE
# Rebuilt automatically — large, device-specific index
# ------------------------------------------------------------
.smart-env/

# ------------------------------------------------------------
# GOOGLE DRIVE TEMP UPLOADS
# Staging artifacts from Google Drive desktop client
# ------------------------------------------------------------
.tmp.driveupload/

# ------------------------------------------------------------
# WINDOWS / DESKTOP ARTIFACTS
# ------------------------------------------------------------
desktop.ini
**/desktop.ini
Thumbs.db
ehthumbs.db

# ------------------------------------------------------------
# MACOS / IPHONE / IPAD ARTIFACTS
# .DS_Store appears on macOS, iPhone Files app, and iPad
# ._* are AppleDouble resource fork files from macOS/iOS sync
# ------------------------------------------------------------
.DS_Store
**/.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# IPHONE / IPAD — iCloud Drive artifacts
# These appear when vault is accessed via iCloud on iOS
# ------------------------------------------------------------
*.icloud
.iCloud
Icon\r

# ------------------------------------------------------------
# PYTHON RUNTIME
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# EDITOR / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# LOGS (generated by BrainOS scripts — do not commit)
# ------------------------------------------------------------
05-INDEX/backfill_frontmatter_log.txt
05-INDEX/inject_open_questions_log.txt
05-INDEX/review_financial_questions_log.txt
