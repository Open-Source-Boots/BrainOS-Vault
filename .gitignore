# ============================================================
# BRAINOS VAULT — .gitignore
# Device-aware: Desktop/PC, Laptop, iPhone, iPad
# Last updated: 2026-05-01
# ============================================================

# ------------------------------------------------------------
# SYNCTHING ARTIFACTS (all devices)
# ------------------------------------------------------------
.stfolder
.stfolder/
.stfolder.removed-*/
.stignore
~syncthing~*
*.sync-conflict-*

# ------------------------------------------------------------
# OBSIDIAN SYNC CONFLICTS (all devices)
# ------------------------------------------------------------
.obsidian/*.sync-conflict-*.json

# ------------------------------------------------------------
# OBSIDIAN WORKSPACE STATE
# Per-device UI state — never commit, causes constant noise
# ------------------------------------------------------------
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ------------------------------------------------------------
# OBSIDIAN PLUGIN DATA (selective)
# ------------------------------------------------------------
.obsidian/plugins/google-drive-sync/
.obsidian/plugins/smart-connections/

# ------------------------------------------------------------
# SMART CONNECTIONS CACHE
# ------------------------------------------------------------
.smart-env/

# ------------------------------------------------------------
# GOOGLE DRIVE TEMP UPLOADS
# ------------------------------------------------------------
.tmp.driveupload/

# ------------------------------------------------------------
# WINDOWS / DESKTOP ARTIFACTS
# ------------------------------------------------------------
desktop.ini
**/desktop.ini
Thumbs.db
ehthumbs.db

# ------------------------------------------------------------
# MACOS / IPHONE / IPAD ARTIFACTS
# ------------------------------------------------------------
.DS_Store
**/.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# IPHONE / IPAD — iCloud Drive artifacts
# ------------------------------------------------------------
*.icloud
.iCloud
Icon\r

# ------------------------------------------------------------
# PYTHON RUNTIME
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# EDITOR / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# LOGS (generated by BrainOS scripts — do not commit)
# ------------------------------------------------------------
05-INDEX/backfill_frontmatter_log.txt
05-INDEX/inject_open_questions_log.txt
05-INDEX/review_financial_questions_log.txt

# ------------------------------------------------------------
# FINANCIAL DOCUMENTS — PDFs tracked via Drive, not Git
# Raw statements, pay stubs, debt docs are binary files.
# Git is not suited for binary history. Drive is the archive.
# Extracted .md files in 00-INBOX ARE committed (text only).
# ------------------------------------------------------------
08-ATTACH/FINANCE/STATEMENTS/*.pdf
08-ATTACH/FINANCE/PAYSTUBS/*.pdf
08-ATTACH/FINANCE/DEBT/*.pdf
08-ATTACH/FINANCE/LEGAL/*.pdf
08-ATTACH/FINANCE/PROCESSED/*.pdf
desktop.ini
Desktop.ini
